<Window x:Class="PdfCounter.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PDF Counter"
        Height="560"
        Width="720"
        MinHeight="400"
        MinWidth="480"
        Background="{StaticResource BgBrush}"
        FontFamily="Segoe UI"
        FontSize="13"
        AllowDrop="True"
        DragEnter="Window_DragEnter"
        DragOver="Window_DragOver"
        DragLeave="Window_DragLeave"
        Drop="Window_Drop">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border x:Name="DropZone"
                Grid.Row="0"
                Padding="28"
                Margin="0,0,0,12"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="2"
                CornerRadius="8"
                AllowDrop="True"
                DragEnter="DropZone_DragEnter"
                DragLeave="DropZone_DragLeave"
                DragOver="DropZone_DragOver"
                Drop="DropZone_Drop">
            <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="Перетащите сюда PDF или папку"
                           FontSize="15"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource TextBrush}"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="Подпапки учитываются автоматически"
                           Margin="0,6,0,0"
                           Foreground="{StaticResource MutedBrush}"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>

        <TabControl Grid.Row="1" Background="Transparent" BorderThickness="0">
            <TabItem Header="По папкам">
                <DataGrid x:Name="FoldersGrid"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal"
                          Background="{StaticResource SurfaceBrush}"
                          BorderBrush="{StaticResource BorderBrush}"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          SelectionMode="Single">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Папка" Binding="{Binding DisplayPath}" Width="*"/>
                        <DataGridTextColumn Header="Файлов" Binding="{Binding FileCount}" Width="70"/>
                        <DataGridTextColumn Header="Листов" Binding="{Binding PageCount}" Width="80"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
            <TabItem Header="По файлам">
                <DataGrid x:Name="FilesGrid"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal"
                          Background="{StaticResource SurfaceBrush}"
                          BorderBrush="{StaticResource BorderBrush}"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          SelectionMode="Single">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Файл" Binding="{Binding RelativePath}" Width="*"/>
                        <DataGridTextColumn Header="Листов" Binding="{Binding PageCount}" Width="80"/>
                        <DataGridTextColumn Header="Ошибка" Binding="{Binding Error}" Width="120"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
        </TabControl>

        <Border Grid.Row="2"
                Margin="0,12,0,0"
                Padding="12,10"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="StatusText"
                           Foreground="{StaticResource MutedBrush}"
                           VerticalAlignment="Center"
                           Text="Готово к работе"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <TextBlock x:Name="TotalFilesText"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextBrush}"
                               Margin="0,0,16,0"/>
                    <TextBlock x:Name="TotalPagesText"
                               FontSize="15"
                               FontWeight="Bold"
                               Foreground="{StaticResource AccentBrush}"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
